      "Beta": { "distribution": "isotropic_latitude" },
      "iota": { "distribution": "isotropic_polar" },
      "var_phi": { "distribution": "uniform", "low": 0.0, "high": 6.283185307179586 },
      "phi_c": { "distribution": "uniform", "low": 0.0, "high": 6.283185307179586 }
    },
    "use_catalog_psi_for_polarization": true
  }
}
