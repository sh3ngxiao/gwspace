{
  "dataset": {
    "name": "tianqin_dc_bbh_catalog_simple",
    "description": "Simple BBH-only TianQin XYZ dataset generated from a BP2P source table."
  },
  "seed": 20260424,
  "catalog": {
    "path": "tianqin_dc/codes/bp2p_bbh_catalogs/catalog_001.csv",
