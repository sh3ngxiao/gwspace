{
  "dataset": {
    "name": "tianqin_dc_emri_catalog_batch",
    "description": "Batch-style EMRI-only TianQin XYZ dataset sampled across multiple EMRI_source catalogs."
  },
  "seed": 20260408,
  "catalog": {
    "path_glob": "tianqin_dc/EMRI_source/*.OUT",
    "selection": "random",
    "rows_per_file": 2,
    "max_sources": 4
  },
  "observation": {
    "duration_s": 63072000.0,
    "sample_rate_hz": 0.2,
    "detector": "TQ",
    "tdi_generation": 1,
    "use_gpu": false
  },
  "output": {
    "path": "outputs/tianqin_dc_emri_catalog_batch.h5",
    "overwrite": true,
    "compression": "gzip",
    "compression_level": 4
  },
  "emri": {
    "use_catalog_inclination_for_x0": true,
    "fixed": {
      "p0": 12.0,
      "backend": "cpu"
    },
    "sampler": {
      "e0": { "distribution": "uniform", "low": 0.0, "high": 0.2 },
      "qS": { "distribution": "isotropic_polar" },
      "phiS": { "distribution": "uniform", "low": 0.0, "high": 6.283185307179586 },
      "qK": { "distribution": "isotropic_polar" },
      "phiK": { "distribution": "uniform", "low": 0.0, "high": 6.283185307179586 },
      "Phi_phi0": { "distribution": "uniform", "low": 0.0, "high": 6.283185307179586 },
      "Phi_theta0": { "distribution": "uniform", "low": 0.0, "high": 6.283185307179586 },
      "Phi_r0": { "distribution": "uniform", "low": 0.0, "high": 6.283185307179586 }
    }
  }
}
