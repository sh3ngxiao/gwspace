{
  "dataset": {
    "name": "tianqin_dc_only_dwd",
    "description": "DWD-only TianQin prototype dataset."
  },
  "seed": 20260410,
  "observation": {
    "duration_s": 4096.0,
    "sample_rate_hz": 0.25,
    "detector": "TQ",
    "tdi_generation": 1,
    "channels": ["A", "E", "T"],
    "use_gpu": false
  },
  "noise": {
    "enabled": true,
    "model": "TQ",
    "unit": "relative_frequency",
    "include_confusion": false
  },
  "output": {
    "path": "outputs/tianqin_dc_only_dwd.h5",
    "overwrite": true,
    "compression": "gzip",
    "compression_level": 4,
    "save_signal": true,
    "save_noise": true,
    "save_per_source": true
  },
  "sources": [
    {
      "kind": "dwd",
      "name": "dwd_population",
      "role": "target",
      "count": 3,
      "sampler": {
        "mass1": { "distribution": "uniform", "low": 0.35, "high": 0.85 },
        "mass2": { "distribution": "uniform", "low": 0.25, "high": 0.75 },
        "DL": { "distribution": "loguniform", "low": 0.002, "high": 0.03 },
        "phi0": { "distribution": "uniform", "low": 0.0, "high": 6.283185307179586 },
        "f0": { "distribution": "uniform", "low": 0.001, "high": 0.004 },
        "psi": { "distribution": "uniform", "low": 0.0, "high": 3.141592653589793 },
        "iota": { "distribution": "uniform", "low": 0.0, "high": 3.141592653589793 },
        "Lambda": { "distribution": "uniform", "low": 0.0, "high": 6.283185307179586 },
        "Beta": { "distribution": "uniform", "low": -1.2, "high": 1.2 }
      }
    }
  ]
}
