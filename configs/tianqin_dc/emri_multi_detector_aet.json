{
  "dataset": {
    "name": "tianqin_dc_emri_multi_detector_aet",
    "description": "Generate EMRI A/E/T time-domain responses for TQ, Taiji, and LISA from the selected EMRI catalog source."
  },
  "source_config": "configs/tianqin_dc/emri_catalog_simple.json",
  "detectors": [
    "TQ",
    "Taiji",
    "LISA"
  ],
  "observation": {
    "duration_s": 63072000.0,
    "sample_rate_hz": 0.2
  },
  "output": {
    "directory": "outputs/multi_detector_aet/emri_catalog_simple",
    "prefix": "emri_catalog_simple_multi_detector_aet"
  },
  "plot": {
    "max_points": 2000000
  }
}
